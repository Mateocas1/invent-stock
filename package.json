{
  "name": "invent-stock",
  "version": "1.0.0",
  "description": "Inventory Management Bot for Nail Salons",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "migrate": "tsx src/infrastructure/database/migrations/run-migrations.ts",
    "seed": "tsx src/infrastructure/database/seeds/run-seeds.ts",
    "typecheck": "tsc --noEmit",
    "health": "node tests/smoke/run-smoke-tests.js",
    "test:smoke": "node tests/smoke/run-smoke-tests.js",
    "backup": "tsx scripts/backup.ts",
    "postinstall": "echo 'Optional: npm install express node-cron for production features'"
  },
  "keywords": [
    "inventory",
    "telegram-bot",
    "nail-salon",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/express": "^5.0.6",
    "better-sqlite3": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.65.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^22.0.0",
    "@types/node-telegram-bot-api": "^0.64.6",
    "@types/pg": "^8.11.2",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
